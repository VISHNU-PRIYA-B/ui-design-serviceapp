import React, {useContext,useState,useLayoutEffect,useEffect,} from "react";
import {View,Text,TextInput,TouchableOpacity,Modal,StyleSheet,Alert,ScrollView,Animated,KeyboardAvoidingView,Platform,TouchableWithoutFeedback,Keyboard,} from "react-native";
import { graphqlRequest, setAuthToken } from "../services/api";
import { UserContext } from "../components/ui/UserContext";
import { useNavigation } from "@react-navigation/native";
import AsyncStorage from "@react-native-async-storage/async-storage";
import { openWhatsApp } from "../utils/whatsapp";
import { LinearGradient } from "expo-linear-gradient";
import { Ionicons } from "@expo/vector-icons";

export default function CreateRepairRequest() {
  const { token: contextToken } = useContext(UserContext);
  const [customerName, setCustomerName] = useState("");
  const [itemName, setItemName] = useState("");
  const [problemDescription, setProblemDescription] = useState("");
  const [contactInfo, setContactInfo] = useState("");
  const [popupVisible, setPopupVisible] = useState(false);
  const [loading, setLoading] = useState(false);
  const [showWhatsAppModal, setShowWhatsAppModal] = useState(false);
  const [popupStep,setPopupStep]=useState(1);
  const [requestId, setRequestId] = useState(null);
  const [lastRequestData, setLastRequestData] = useState(null);
  
  const [whatsAppData, setWhatsAppData] = useState({
    phone: "",
    message: "",
  });

  const navigation = useNavigation();
  const scaleAnim = useState(new Animated.Value(0))[0];

  useLayoutEffect(() => {
    navigation.setOptions({
      headerShown: false,
    });
  }, [navigation]);

  useEffect(() => {
    if (popupVisible) {
      Animated.spring(scaleAnim, {
        toValue: 1,
        friction: 5,
        useNativeDriver: true,
      }).start();
    } else {
      scaleAnim.setValue(0);
    }
  }, [popupVisible]);

  const handleCreate = async () => {
    if (!customerName || !itemName || !problemDescription || !contactInfo) {
      Alert.alert("Missing Information", "Please fill all fields");
      return;
    }

    const tokenToUse = contextToken || (await AsyncStorage.getItem("token"));
    if (!tokenToUse) {
      Alert.alert("Error", "You are not logged in");
      return;
    }

    setAuthToken(tokenToUse);

    const query = `
      mutation CreateRepairRequest(
        $customerName: String!
        $itemName: String!
        $problemDescription: String!
        $contactInfo: String!
      ) {
        createRepairRequest(
          customerName: $customerName
          itemName: $itemName
          problemDescription: $problemDescription
          contactInfo: $contactInfo
        ) {
          repairRequest {
            requestId
            status
          }
        }
      }
    `;

    try {
      setLoading(true);

      const res = await graphqlRequest(query, {
        customerName,
        itemName,
        problemDescription,
        contactInfo,
      });
      if (res?.createRepairRequest?.repairRequest) {
        const { requestId: newRequestId } = res.createRepairRequest.repairRequest;

        setRequestId(newRequestId);
        setLastRequestData({
          requestId: newRequestId,
          customerName,
          itemName,
          problemDescription,
          contactInfo,
        });

        setWhatsAppData({
          phone: contactInfo,
          message: `Repair Request Created

      Customer Name: ${customerName}
      Item: ${itemName}
      Issue: ${problemDescription}

      Our team will contact you shortly.`,
        });

        setPopupStep(1);
        setPopupVisible(true);

        setCustomerName("");
        setItemName("");
        setProblemDescription("");
        setContactInfo("");
      } else {
        Alert.alert("Error", "Failed to create repair request");
      }
    } catch (error) {
      Alert.alert("Please fill the mobile number correctly");
    } finally {
      setLoading(false);
    }
  };

  const handlePopupClose = () => {
    setPopupVisible(false);
    navigation.navigate("Profile");
  };

  return ( 
    <KeyboardAvoidingView
      style={{ flex: 1 }}
      behavior={Platform.OS === "ios" ? "padding" : "height"}
      keyboardVerticalOffset={90}
    >
      <TouchableWithoutFeedback onPress={Keyboard.dismiss}>
        <View style={styles.container}>
          <ScrollView showsVerticalScrollIndicator={false}>
            <LinearGradient
              colors={["#A78BFA", "#8B5CF6"]}
              start={{ x: 0, y: 0 }}
              end={{ x: 1, y: 1 }}
              style={styles.headerBackground}
            >
              <View style={styles.headerTop}>
          <TouchableOpacity 
            style={styles.backButton}
            onPress={() => navigation.goBack()}
          >
            <Ionicons name="arrow-back" size={25} color="#fff"  />
          </TouchableOpacity>
                </View>
              <Text style={styles.headerTitle}>Create Repair Request</Text>
              <Text style={styles.headerSubtitle}>
                Fill in the details below
              </Text>
            </LinearGradient>

            <View style={styles.card}>
              {/* Customer Name */}
              <View style={styles.inputContainer}>
                <Text style={styles.label}>Customer Name</Text>
                <View style={styles.inputWrapper}>
                  <Text style={styles.inputIcon}>👤</Text>
                  <TextInput
                    style={styles.input}
                    value={customerName}
                    onChangeText={setCustomerName}
                    placeholder="Enter your name"
                    placeholderTextColor="#C4C4C4"
                  />
                </View>
              </View>

              {/* Item Name */}
              <View style={styles.inputContainer}>
                <Text style={styles.label}>Item Name</Text>
                <View style={styles.inputWrapper}>
                  <Text style={styles.inputIcon}>📦</Text>
                  <TextInput
                    style={styles.input}
                    value={itemName}
                    onChangeText={setItemName}
                    placeholder="Ex: Laptop / Phone"
                    placeholderTextColor="#C4C4C4"
                  />
                </View>
              </View>
              {/* Problem Description */}
              <View style={styles.inputContainer}>
                <Text style={styles.label}>Problem Description</Text>
                <TextInput
                  style={[styles.input, styles.textarea]}
                  value={problemDescription}
                  onChangeText={setProblemDescription}
                  multiline
                  placeholder="Describe the problem..."
                  placeholderTextColor="#C4C4C4"
                />
              </View>
              {/* Contact Info */}
              <View style={styles.inputContainer}>
                <Text style={styles.label}>Contact Info</Text>
                <View style={styles.inputWrapper}>
                  <Text style={styles.inputIcon}>📱</Text>
                  <TextInput
                    style={styles.input}
                    keyboardType="numeric"
                    value={contactInfo}
                    onChangeText={setContactInfo}
                    placeholder="Phone Number"
                    placeholderTextColor="#C4C4C4"
                  />
                </View>
              </View>
              <TouchableOpacity
                style={styles.submitButton}
                onPress={handleCreate}
                disabled={loading}
              >
                <LinearGradient
                  colors={["#A78BFA", "#8B5CF6"]}
                  style={styles.gradientButton}
                >
                  <Text style={styles.buttonText}>
                    {loading ? "Submitting..." : "Submit Request"}
                  </Text>
                </LinearGradient>
              </TouchableOpacity>
              <TouchableOpacity
                style={styles.createBillButton}
                onPress={() => {
                  if (!lastRequestData) {
                    Alert.alert("No Request Yet", "Please submit a repair request first");
                    return;
                  }
                  navigation.navigate("AddEstimation", { ...lastRequestData });
                }}
              >
                <LinearGradient colors={["#A78BFA", "#8B5CF6"]} style={styles.gradientButton}>
                  <Text style={styles.buttonText}>Create Bill</Text>
                </LinearGradient>
              </TouchableOpacity>
            </View>
          </ScrollView>

          {/* SUCCESS MODAL */}
          <Modal transparent visible={popupVisible}>
            <View style={styles.popupContainer}>
              <Animated.View
                style={[
                  styles.popupBox,
                  { transform: [{ scale: scaleAnim }] },
                ]}
              >
              {popupStep === 1 && (

              <>
                          <Text style={styles.popupTitle}>Request Submitted!</Text>
            <Text style={styles.popupMessage}>
              Your repair request has been submitted successfully.
            </Text>

            <TouchableOpacity
              onPress={() => setPopupStep(2)}
              style={{ marginTop: 20 }}
            >
              <Text style={{ color: "#8B5CF6", fontSize: 16, fontWeight: "700",textAlign:"center" }}>
                OK
              </Text>
            </TouchableOpacity>
          </>
        )}
        {popupStep===2 &&(
          <>
   
                <Text style={styles.popupMessage}>
                  Do you want to send details to customer via WhatsApp?
                </Text>
              
                <TouchableOpacity
                  onPress={() => {
                    openWhatsApp(
                      whatsAppData.phone,
                      whatsAppData.message
                    );
                    handlePopupClose();
                  }}
                >
                  <Text style={{ color: "#8B5CF6", marginTop: 20 }}>
                    Send via WhatsApp
                  </Text>
                </TouchableOpacity>
                <TouchableOpacity
                  onPress={() => setPopupVisible(false)}
                  style={styles.cancelButton}
                >
                  <Text style={{ color: "red", fontSize: 16 }}>
                    Cancel
                  </Text>
                </TouchableOpacity>
                </>
        )}
              </Animated.View>
            </View>
          </Modal>
        </View>
      </TouchableWithoutFeedback>
    </KeyboardAvoidingView>
  );
}

